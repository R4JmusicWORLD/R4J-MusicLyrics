# ─── Telegram API Credentials ────────────────────────────────────────────────
# Get these from https://my.telegram.org
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# ─── LICENSE KEY (REQUIRED) ──────────────────────────────────────────────────
# You MUST get a license key from the owner to deploy this bot.
# Contact @R4J_81 on Telegram and send your BOT_TOKEN to receive your key.
# Format: ML-XXXXXXXX-XXXXXXXX
LICENSE_KEY=

# Bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# String session for userbot (pytgcalls assistant)
# Generate using: python3 -m pyrogram generate
STRING_SESSION=

# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB connection URI
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# ─── Bot Configuration ──────────────────────────────────────────────────────
# Space-separated Telegram user IDs with sudo privileges
SUDO_USERS=123456789 987654321

# Owner's Telegram user ID (defaults to first SUDO_USERS entry)
OWNER_ID=123456789

# Telegram group/channel ID for logging bot events
LOG_GROUP_ID=-1001234567890

# ─── Support Links ──────────────────────────────────────────────────────────
SUPPORT_GROUP=https://t.me/+OvozYu7R1EczMGJl
SUPPORT_CHANNEL=https://t.me/RupkothaGolpo

# ─── Optional ────────────────────────────────────────────────────────────────
# Google Gemini API key for AI chat features (optional)
# Get it from https://aistudio.google.com/apikey
# AI_API_KEY=

# Spotify credentials for Spotify track support (optional)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# YouTube API key (optional, for search)
# YOUTUBE_API_KEY=

# Cobalt API key (optional, for cloud-friendly YouTube stream extraction)
# Get it from https://cobalt.tools/ (required since Cobalt v10+)
# COBALT_API_KEY=

# ─── YouTube Cookies (optional but recommended) ───────────────────────────────
# YouTube cookies help avoid "Sign in to confirm you're not a bot" errors
# on cloud servers. Export cookies from a logged-in browser session as
# Netscape-format .txt files and place them in the cookies/ directory.
# Multiple cookie files are supported (one is randomly selected per request).

# For cloud deploys (Heroku/Railway/Render) where you can't add files,
# paste the FULL content of your cookies.txt into this variable:
# COOKIES_TXT=# Netscape HTTP Cookie File\n.youtube.com\tTRUE\t/\tTRUE\t0\tCOOKIE_NAME\tVALUE
# (Use the actual multi-line content — Heroku Config Vars support multi-line values)

# YouTube PO (Proof of Origin) token for extra bot-detection bypass (optional, advanced):
# YT_PO_TOKEN=

# ─── YouTube Proxy (REQUIRED for Heroku/cloud) ──────────────────────────────
# YouTube blocks Heroku/Railway/Render IPs. A proxy is ESSENTIAL for cloud.
# Without this, YouTube streaming WILL NOT WORK on cloud platforms.
# Format: http://user:pass@host:port  OR  socks5://host:port
# Get a cheap residential proxy from: webshare.io, smartproxy, oxylabs, etc.
# YOUTUBE_PROXY=http://user:pass@proxy.example.com:8080

# ─── YouTube Proxy Rotation (RECOMMENDED) ───────────────────────────────────
# Multiple proxies for rotation (avoids single-proxy rate limits).
# Comma-separated. Supports multiple formats:
#   - Webshare format:  ip:port:user:pass
#   - Standard format:  http://user:pass@host:port
# Example with Webshare proxies:
# YOUTUBE_PROXY_LIST=38.154.203.95:5863:myuser:mypass,198.105.121.200:6462:myuser:mypass
